[Unit]
Description=PingFederate
After=network.target

[Service]
Type=simple
User=pingusr
Group=pingusr
WorkingDirectory=/opt/ping/pingfederate/bin
Environment='JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64/'
ExecStart=/opt/ping/pingfederate/bin/run.sh
ExecStop=/opt/ping/pingfederate/sbin/pingfederate-shutdown.sh
Restart=on-failure
RestartSec=10
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
